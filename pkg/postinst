#!/bin/sh
# Offline image build (opkg in a staging root): do nothing on-target work.
[ -n "${IPKG_INSTROOT}" ] && exit 0

fail() { echo "empwifi: $1" >&2; exit 1; }

# 1. Require firmware-4.x oui layout + the repeater backend we wrap.
[ -d /usr/share/oui/menu.d ]      || fail "not a firmware-4.x (oui) device; aborting"
[ -d /usr/lib/oui-httpd/rpc ]     || fail "oui rpc directory missing; aborting"
[ -e /usr/lib/oui-httpd/rpc/repeater ] || fail "repeater backend missing; this device cannot run Employee WiFi"

# 1b. On FIRST install only, seed a random employee-page password so the page is never left
#     open with no/default credentials. Guarded by an 'initialized' flag (survives upgrades
#     as a conffile) AND an empty emp_password, so an upgrade never overwrites a real setting.
#     Also skipped when no_password='1': the admin has deliberately made the page passwordless,
#     so a generated password would be pointless clutter. Stored as plaintext for the admin
#     page to display and hand out; the Lua backend hashes it on first use. The admin can
#     replace it any time (which clears the plaintext).
if [ "$(uci -q get empwifi.global.initialized)" != "1" ] \
   && [ -z "$(uci -q get empwifi.global.emp_password)" ] \
   && [ "$(uci -q get empwifi.global.no_password)" != "1" ]; then
	pw="$(tr -dc 'ABCDEFGHJKLMNPQRSTUVWXYZabcdefghijkmnpqrstuvwxyz23456789' < /dev/urandom | head -c 10)"
	[ -n "$pw" ] || pw="$(head -c 8 /dev/urandom | md5sum | head -c 10)"   # fallback, never blank
	uci -q set empwifi.global='empwifi'
	uci set empwifi.global.emp_password_plain="$pw"
	uci set empwifi.global.initialized='1'
	uci commit empwifi
fi

# 2. Register the employee methods as no-auth so the public /wifi page can reach them
#    without an admin session (the methods enforce the employee password inside Lua).
#    Drop any existing empwifi section first, then re-add with the current method list: an
#    older install's section will not list methods added in later versions (e.g. emp_health),
#    so recreating keeps the no-auth set in sync on every upgrade. Deleting an anonymous
#    section renumbers the rest, so do NOT advance the index on a delete.
i=0
while uci -q get "oui-httpd.@no-auth-methods[$i]" >/dev/null 2>&1; do
	if [ "$(uci -q get "oui-httpd.@no-auth-methods[$i].object")" = "empwifi" ]; then
		uci -q delete "oui-httpd.@no-auth-methods[$i]"
	else
		i=$((i + 1))
	fi
done
sec="$(uci add oui-httpd no-auth-methods)"
uci set oui-httpd."$sec".object='empwifi'
for m in emp_login emp_scan emp_join emp_status emp_list emp_health; do
	uci add_list oui-httpd."$sec".method="$m"
done
uci commit oui-httpd

# 3. Reload nginx so fresh workers pick up the new no-auth methods (the no_auth_methods
#    dict is a per-worker Lua upvalue) and the /wifi location. Use `nginx -s reload`
#    (HUP -> graceful fresh workers); the init script's `reload` is a no-op on this
#    firmware, and a full restart would drop the admin's session mid-install.
nginx -s reload 2>/dev/null || /etc/init.d/nginx restart 2>/dev/null || true

exit 0
